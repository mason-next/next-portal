# PostgreSQL connection string
# Railway provides this automatically as DATABASE_URL — no manual setup needed in production.
# For local development, copy this file to .env.local and fill in your values.
#
#   Railway:  Dashboard → Project → your Postgres service → Connect → "Prisma" tab
#   Local:    Use a local Postgres instance or a Railway preview environment
#
DATABASE_URL="postgresql://user:password@host:5432/next_portal?sslmode=require"

# Optional: direct (non-pooled) connection for Prisma migrations.
# Required only if you are using a connection pooler like PgBouncer or Railway's proxy.
# DIRECT_URL="postgresql://user:password@host:5432/next_portal?sslmode=require"

# ─── Email ────────────────────────────────────────────────────────────────────
# Controls which email backend is used for @mention and other notification emails.
# In-app notifications (the bell icon) always work regardless of this setting.
#
# Supported values:
#   disabled         — logs intent, never sends externally (safe default for dev/staging)
#   microsoft_graph  — Microsoft Graph API (requires AZURE_* vars below)
#   resend           — Resend SDK (requires RESEND_API_KEY; kept as a fallback option)
#
EMAIL_PROVIDER=disabled

# Public app URL — used to build deep links inside notification emails.
NEXT_PUBLIC_APP_URL="https://your-app-url.com"

# ─── Microsoft Graph (EMAIL_PROVIDER=microsoft_graph) ─────────────────────────
# Register an app in Azure AD with Mail.Send permission (application, not delegated).
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# GRAPH_FROM_EMAIL=notifications@yourdomain.com

# ─── Resend fallback (EMAIL_PROVIDER=resend) ──────────────────────────────────
# Only needed if switching back to Resend. Verify your sending domain in resend.com first.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL="NEXT Portal <notifications@yourdomain.com>"

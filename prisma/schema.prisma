generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

// Controls app permissions / access level.
enum AccountType {
  Administrator
  Member
  Viewer
}

// Controls functional group / reporting / filtering — not permissions.
enum RoleType {
  // Current values
  Sales
  Engineering
  ProjectManagement
  Management
  Installation
  Finance
  Customer
  Subcontractor
  // Legacy values (deprecated — kept so old rows remain valid)
  Engineer
  Salesperson
  ProjectManager
  Technician
  Operations
  Executive
  HR
  FieldTechnician
  Vendor
  Other
}

enum ProjectMemberRole {
  SolutionsExecutive  @map("Solutions Executive")
  SolutionsEngineer   @map("Solutions Engineer")
  LeadTechnician      @map("Lead Technician")
  FieldProjectManager @map("Field Project Manager")
  SeniorInside        @map("Senior Inside")
  ProjectManager      @map("Project Manager")
  InsidePM            @map("Inside PM")
}

enum ActivityCategory {
  comment
  workflow
  status_change
  system
}

enum WorkflowSection {
  setup
  engineering
  procurement
  implementation
  closeout
  serviceWarranty
}

enum WorkflowStepStatus {
  NotStarted @map("Not Started")
  InProgress @map("In Progress")
  Complete
  NotNeeded  @map("Not Needed")
}

enum BomStatus {
  NotReviewed         @map("Not Reviewed")
  Approved
  PendingVerification @map("Pending Verification")
  SwapReplace         @map("Swap/Replace")
  DoNotOrder          @map("Do Not Order")
  OnHold              @map("On Hold")
  Released
  Ordered
  Received
  Installed
}

enum EquipmentSource {
  csv
  connectwise
}

enum DealStatus {
  Pending
  Approved
  Rejected
}

enum CommissionStatus {
  Estimated
  PendingApproval @map("Pending Approval")
  Approved
  Paid
}

// ─── Subcontractors ──────────────────────────────────────────────────────────

model Subcontractor {
  id                String   @id @default(cuid())
  name              String
  trade             String   @default("")
  contactName       String   @default("")
  contactEmail      String   @default("")
  contactPhone      String   @default("")
  location          String   @default("")
  manpower          Int      @default(0)
  geographicalReach String   @default("")
  rating            Float?
  notes             String   @default("")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  projectTechnicians ProjectTechnician[]

  @@map("subcontractors")
}

// Many-to-many: a project can have multiple technician assignments.
// Each row represents either an internal user (userId set) or an external
// subcontractor (subcontractorId set). Exactly one of the two must be non-null.
model ProjectTechnician {
  id              String         @id @default(cuid())
  projectId       String
  userId          String?
  subcontractorId String?
  createdAt       DateTime       @default(now())

  project       Project        @relation(fields: [projectId],       references: [id], onDelete: Cascade)
  user          User?          @relation("ProjectTechUser",         fields: [userId],          references: [id], onDelete: SetNull)
  subcontractor Subcontractor? @relation(fields: [subcontractorId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@map("project_technicians")
}

enum ImplementationTaskStatus {
  NotStarted @map("Not Started")
  InProgress @map("In Progress")
  Blocked
  Complete
  Cancelled
}

enum TaskPriority {
  Low
  Medium
  High
  Critical
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id               String      @id
  name             String
  title            String
  email            String      @unique
  phone            String      @default("")
  avatarUrl        String?
  accountType      AccountType @default(Member)
  roleType         RoleType    @default(Other)
  isActive           Boolean     @default(true)
  passwordHash       String?
  mustChangePassword Boolean     @default(false)
  roleTypes        String[]    @default([])
  department       String      @default("")
  location         String      @default("")
  region           String      @default("")
  emergencyContact String      @default("")
  adminNotes       String      @default("")
  bioDescription   String?     @map("bio_description")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  projectMembers        ProjectMember[]
  workflowSteps         WorkflowStep[]              @relation("StepOwner")
  activities            ProjectActivity[]
  notifications         Notification[]
  commentMentions       CommentMention[]
  assignedImplTasks     ImplementationTask[]        @relation("ImplTaskAssignee")
  implTaskAssignments   ImplementationTaskAssignee[] @relation("ImplTaskAssigneeJoin")
  createdImplTasks      ImplementationTask[]        @relation("ImplTaskCreatedBy")
  implTaskComments      ImplementationTaskComment[] @relation("ImplTaskCommentAuthor")
  technicianAssignments  ProjectTechnician[]         @relation("ProjectTechUser")
  certifications         UserCertification[]

  @@map("users")
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]

  @@map("customers")
}

// ─── Projects ────────────────────────────────────────────────────────────────

model Project {
  id                   String    @id
  name                 String
  projectNumber        String    @unique
  // Denormalized for fast display — customerId is the normalized FK when set.
  customerName         String
  customerId           String?
  siteAddress          String
  coordinatorGroup     String
  contractValue        Float
  grossProfit          Float
  // Role assignment fields — stored as plain strings so "not-needed" sentinel is valid.
  // ProjectMember join table holds the normalized form; these are the canonical read source.
  solutionsExecutiveId  String?
  solutionsEngineerId   String?
  leadTechnicianId      String?
  fieldProjectManagerId String?
  seniorInsideId        String?
  projectManagerId      String?
  insidePMId            String?
  targetCompletionDate DateTime?
  technicianNotNeeded  Boolean   @default(false)
  projectTypes         String[]  @default([])
  connectwiseUrl       String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  customer             Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  members              ProjectMember[]
  workflowSteps        WorkflowStep[]
  activities           ProjectActivity[]
  notifications        Notification[]
  commentMentions      CommentMention[]
  bomRows              BomRow[]
  releases             Release[]
  equipmentRows        EquipmentRow[]
  equipmentUploads     EquipmentUpload[]
  welcomeLetter        WelcomeLetter?
  internalKickoff      InternalKickoff?
  technicalKickoff     TechnicalKickoff?
  implementationTasks  ImplementationTask[]
  technicians          ProjectTechnician[]
  meetingNotes         MeetingNote[]

  @@map("projects")
}

// One row per project role. Replaces the four nullable FK columns on Project.
// "Not needed" is represented by the absence of a row, not a sentinel value.
model ProjectMember {
  id        String            @id @default(cuid())
  projectId String
  userId    String
  role      ProjectMemberRole
  createdAt DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([projectId, role])
  @@index([projectId])
  @@map("project_members")
}

// ─── Workflow ─────────────────────────────────────────────────────────────────

model WorkflowStep {
  id               String             @id
  projectId        String
  key              String
  name             String
  section          WorkflowSection
  weight           Float
  status           WorkflowStepStatus @default(NotStarted)
  ownerId          String?
  dueDate          DateTime?
  completedDate    DateTime?
  sortOrder        Int
  statusOverridden Boolean            @default(false)
  weightOverridden Boolean            @default(false)
  isCustom         Boolean            @default(false)
  isExcluded       Boolean            @default(false) @map("is_excluded")
  description      String             @default("")
  dependsOnKeys    String[]           @default([])
  completionRule   String             @default("manual")
  updatedAt        DateTime           @updatedAt

  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner               User?                @relation("StepOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  implementationTasks ImplementationTask[] @relation("TaskWorkflowStep")

  @@unique([projectId, key])
  @@index([projectId, sortOrder])
  @@map("workflow_steps")
}

// ─── Activity & Comments ──────────────────────────────────────────────────────

// Unified feed: category = "comment" for rich comments, other values for system events.
model ProjectActivity {
  id           String           @id @default(cuid())
  projectId    String
  category     ActivityCategory
  activityType String
  userId       String?
  userName     String
  message      String
  richContent  Json?
  metadata     Json?
  attachments  Json             @default("[]")
  // User-visible tag: "General" (default project comment) | "Status" (customer-facing status update)
  tag          String           @default("General")
  createdAt    DateTime         @default(now())

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User?            @relation(fields: [userId],    references: [id], onDelete: SetNull)
  notifications   Notification[]
  commentMentions CommentMention[]

  @@index([projectId, createdAt(sort: Desc)])
  @@map("project_activities")
}

model Notification {
  id              String   @id @default(cuid())
  userId          String
  type            String   @default("mention")
  projectId       String
  projectName     String
  commentId       String?
  taskCommentId   String?
  commentAuthor   String   @default("")
  commentPreview  String   @default("")
  message         String
  metadata        Json?
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())

  user    User             @relation(fields: [userId],    references: [id], onDelete: Cascade)
  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comment ProjectActivity? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model CommentMention {
  id              String   @id @default(cuid())
  projectId       String
  commentId       String
  mentionedUserId String
  createdAt       DateTime @default(now())

  project       Project         @relation(fields: [projectId],       references: [id], onDelete: Cascade)
  comment       ProjectActivity @relation(fields: [commentId],       references: [id], onDelete: Cascade)
  mentionedUser User            @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@index([mentionedUserId, createdAt(sort: Desc)])
  @@map("comment_mentions")
}

// ─── BOM ──────────────────────────────────────────────────────────────────────

model BomRow {
  id           String    @id @default(cuid())
  projectId    String
  seq          String
  mfr          String
  part         String
  desc         String
  qty          Int
  unitCost     Float
  status       BomStatus @default(NotReviewed)
  // releaseId stores the Release UUID as a plain string (no FK) until Release is DB-migrated.
  // releaseLabel stores the display label ("Release 1") denormalized alongside it.
  releaseId    String?
  releaseLabel String?
  releasedAt   DateTime?
  shippingType String?
  shipTo       String?
  notes        String    @default("")
  sortOrder    Int       @default(0)
  updatedAt    DateTime  @updatedAt

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  auditLog BomAuditLog[]

  @@index([projectId])
  @@map("bom_rows")
}

model BomAuditLog {
  id        String   @id @default(cuid())
  rowId     String
  field     String
  oldValue  String
  newValue  String
  userName  String
  userId    String?
  createdAt DateTime @default(now())

  row BomRow @relation(fields: [rowId], references: [id], onDelete: Cascade)

  @@index([rowId])
  @@map("bom_audit_log")
}

model Release {
  id             String    @id @default(cuid())
  projectId      String
  releaseNumber  String
  shippingType   String    @default("")
  shipTo         String    @default("")
  recipients     String    @default("")
  notes          String    @default("")
  // Null until the draft is finalized via "Generate Release".
  generatedAt    DateTime?
  generatedBy    String    @default("")
  // BomRow.id values included in this release — denormalized for email/PDF rebuild.
  rowIds         String[]  @default([])
  // Frozen point-in-time snapshot of rows at generation — never joined live.
  rowSnapshot    Json      @default("[]")
  emailPlainText String    @default("")
  emailHtml      String    @default("")
  emailSubject   String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("releases")
}

// ─── Equipment ────────────────────────────────────────────────────────────────

// status is always computed via computeEquipmentStatus() — not stored in DB.
model EquipmentRow {
  id              String          @id @default(cuid())
  projectId       String
  seq             String
  mfr             String
  product         String
  desc            String
  qty             Int
  unitCost        Float
  stockAllocation String          @default("")
  specialOrder    String          @default("")
  pickedQty       Int             @default(0)
  shippedQty      Int             @default(0)
  cancelled       String          @default("")
  poInfo          String          @default("")
  rmaRequestedAt  DateTime?
  notNeeded       Boolean         @default(false)
  source          EquipmentSource @default(csv)
  sortOrder       Int             @default(0)
  updatedAt       DateTime        @updatedAt

  project  Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  auditLog EquipmentAuditLog[]

  @@index([projectId])
  @@map("equipment_rows")
}

model EquipmentAuditLog {
  id        String   @id @default(cuid())
  rowId     String
  field     String
  oldValue  String
  newValue  String
  userName  String
  userId    String?
  createdAt DateTime @default(now())

  row EquipmentRow @relation(fields: [rowId], references: [id], onDelete: Cascade)

  @@index([rowId])
  @@map("equipment_audit_log")
}

model EquipmentUpload {
  id           String          @id @default(cuid())
  projectId    String
  fileName     String
  rowCount     Int
  newCount     Int
  updatedCount Int
  removedCount Int             @default(0)
  uploadedBy   String
  uploadedAt   DateTime
  source       EquipmentSource @default(csv)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("equipment_uploads")
}

// ─── Module Records ───────────────────────────────────────────────────────────

model WelcomeLetter {
  id        String   @id @default(cuid())
  projectId String   @unique
  subject   String
  html      String
  plainText String
  sentBy    String
  sentAt    DateTime

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("welcome_letters")
}

model InternalKickoff {
  id          String   @id @default(cuid())
  projectId   String   @unique
  subject     String
  agenda      String
  attendees   String[]
  startTime   DateTime
  endTime     DateTime
  scheduledBy String
  scheduledAt DateTime

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("internal_kickoffs")
}

model TechnicalKickoff {
  id          String   @id @default(cuid())
  projectId   String   @unique
  subject     String
  agenda      String
  attendees   String[]
  startTime   DateTime
  endTime     DateTime
  scheduledBy String
  scheduledAt DateTime

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("technical_kickoffs")
}

model MeetingNote {
  id            String   @id @default(cuid())
  projectId     String
  title         String
  meetingDate   DateTime
  attendees     String[] @default([])
  body          String   @default("")
  actionItems   String   @default("")
  createdById   String?
  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("meeting_notes")
}

// ─── Implementation Tasks ─────────────────────────────────────────────────────

model ImplementationTask {
  id              String                   @id @default(cuid())
  projectId       String?
  isPersonal      Boolean                  @default(false)
  title           String
  description     String                   @default("")
  status          ImplementationTaskStatus @default(NotStarted)
  priority        TaskPriority             @default(Medium)
  percentComplete Int                      @default(0)
  assigneeId      String?
  createdById     String?
  startDate       DateTime?
  dueDate         DateTime?
  completedAt     DateTime?
  sortOrder       Int                      @default(0)
  parentTaskId    String?
  notes           String                   @default("")
  tags            String[]                 @default([])
  workflowStepId      String?
  calendarScheduledAt DateTime?
  calendarEventUrl    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project     Project?           @relation(fields: [projectId],   references: [id], onDelete: SetNull)
  assignee    User?              @relation("ImplTaskAssignee",   fields: [assigneeId],  references: [id], onDelete: SetNull)
  createdBy   User?              @relation("ImplTaskCreatedBy",  fields: [createdById], references: [id], onDelete: SetNull)
  parentTask  ImplementationTask?  @relation("TaskSubtasks",     fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks    ImplementationTask[] @relation("TaskSubtasks")
  dependencies ImplementationTaskDep[] @relation("DepTask")
  dependents   ImplementationTaskDep[] @relation("DepPre")
  comments     ImplementationTaskComment[]
  assignees    ImplementationTaskAssignee[]
  workflowStep WorkflowStep? @relation("TaskWorkflowStep", fields: [workflowStepId], references: [id], onDelete: SetNull)

  @@index([projectId, sortOrder])
  @@index([projectId, parentTaskId])
  @@map("implementation_tasks")
}

model ImplementationTaskDep {
  id          String @id @default(cuid())
  taskId      String
  dependsOnId String

  task      ImplementationTask @relation("DepTask", fields: [taskId],      references: [id], onDelete: Cascade)
  dependsOn ImplementationTask @relation("DepPre",  fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@map("implementation_task_deps")
}

model ImplementationTaskComment {
  id          String   @id @default(cuid())
  taskId      String
  userId      String?
  userName    String
  richContent Json?
  plainText   String   @default("")
  attachments Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task ImplementationTask @relation(fields: [taskId],  references: [id], onDelete: Cascade)
  user User?              @relation("ImplTaskCommentAuthor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt(sort: Desc)])
  @@map("implementation_task_comments")
}

model ImplementationTaskAssignee {
  taskId String @map("task_id")
  userId String @map("user_id")
  task   ImplementationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User               @relation("ImplTaskAssigneeJoin", fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@map("implementation_task_assignees")
}

// ─── Task Templates ───────────────────────────────────────────────────────────

model TaskTemplateGroup {
  id           String             @id @default(cuid())
  name         String
  stepKey      String
  description  String             @default("")
  projectTypes String[]           @default([])
  sortOrder    Int                @default(0)
  isBuiltIn    Boolean            @default(false)
  tasks        TaskTemplateItem[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([stepKey])
  @@map("task_template_groups")
}

model TaskTemplateItem {
  id          String                @id @default(cuid())
  groupId     String
  title       String
  description String                @default("")
  sortOrder   Int                   @default(0)
  group       TaskTemplateGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subtasks    TaskTemplateSubtask[]

  @@index([groupId, sortOrder])
  @@map("task_template_items")
}

model TaskTemplateSubtask {
  id        String           @id @default(cuid())
  taskId    String
  title     String
  sortOrder Int              @default(0)
  task      TaskTemplateItem @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, sortOrder])
  @@map("task_template_subtasks")
}

// ─── Deal Desk ────────────────────────────────────────────────────────────────

model DealDeskQuote {
  id                String           @id @default(cuid())
  customer          String
  projectName       String
  quoteNumber       String
  opportunityNumber String
  revision          String
  version           Int              @default(1)
  projectType       String
  salesperson       String
  salespersonId     String?
  importedAt        DateTime
  importedBy        String
  bookingDate       String?
  quarter           String
  status            DealStatus       @default(Pending)
  commissionStatus  CommissionStatus @default(Estimated)
  categories        Json
  team              Json
  executiveNotes    String           @default("")
  approvalHistory      Json             @default("[]")
  auditLog             Json             @default("[]")
  sourceFiles          String[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  billingCompletionPct Float            @default(0)
  milestones           Json             @default("[]")
  payoutEvents         Json             @default("[]")

  @@map("deal_desk_quotes")
}

// ─── Sales Activity ───────────────────────────────────────────────────────────

// OppStage: renamed from LogoStage in migration 20260627_companies_opps_restructure.
enum OppStage {
  Prospecting
  Qualifying
  Proposal
  Negotiation
  ClosedWon  @map("Closed Won")
  ClosedLost @map("Closed Lost")
}

enum ActivityType {
  Call
  Email
  Meeting
  Research
  Demo
  Proposal
  Other
}

// Replaced sales_logos with a proper relational model.
// Created in migration 20260627_companies_opps_restructure.
model SalesCompany {
  id         String   @id @default(cuid())
  name       String
  domain     String   @default("")
  notes      String   @default("")
  dealDeskId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  opportunities SalesOpportunity[]
  activities    SalesActivity[]

  @@map("sales_companies")
}

model SalesOpportunity {
  id        String   @id @default(cuid())
  companyId String
  name      String
  stage     OppStage @default(Prospecting)
  ownerId   String?
  ownerName String   @default("")
  value     Int      @default(0)
  notes     String   @default("")
  closeDate DateTime?
  cwNumber  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    SalesCompany  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activities SalesActivity[]

  @@index([companyId])
  @@map("sales_opportunities")
}

model SalesActivity {
  id            String       @id @default(cuid())
  userId        String?
  userName      String
  companyId     String?
  opportunityId String?
  type          ActivityType
  description   String       @default("")
  contacts      Json         @default("[]")
  aiGenerated   Boolean      @default(false)
  weekStart     DateTime
  createdAt     DateTime     @default(now())

  company     SalesCompany?     @relation(fields: [companyId],     references: [id], onDelete: SetNull)
  opportunity SalesOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([userId, weekStart])
  @@index([weekStart])
  @@index([companyId])
  @@map("sales_activities")
}

// ─── Quote Portal ─────────────────────────────────────────────────────────────

model QuotePresentation {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  customer     String
  isActive     Boolean  @default(true)
  htmlFile     String   @default("presentation.html")
  storageKey   String   @default("")
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accessLogs QuoteAccessLog[]

  @@map("quote_presentations")
}

model QuoteAccessLog {
  id          String   @id @default(cuid())
  quoteId     String
  email       String
  ip          String   @default("")
  userAgent   String   @default("")
  accessedAt  DateTime @default(now())

  quote QuotePresentation @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, accessedAt(sort: Desc)])
  @@map("quote_access_logs")
}

// ─── Settings ─────────────────────────────────────────────────────────────────

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

// ─── User Certifications ──────────────────────────────────────────────────────

model UserCertification {
  id             String    @id @default(cuid())
  userId         String
  name           String
  issuingOrg     String    @default("")
  expirationDate DateTime?
  notes          String    @default("")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_certifications")
}

// ─── Org Chart Module (Beta) ──────────────────────────────────────────────────
// Feature-flagged via NEXT_PUBLIC_ORG_CHART_ENABLED.
// All tables use the org_ prefix and are fully isolated.
// Removal: drop all org_ tables and remove these models + the User backrelation.

model OrgDepartment {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6366f1")
  status      String   @default("active")
  sortOrder   Int?     @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  positions OrgPosition[]

  @@map("org_departments")
}

model OrgLocation {
  id      String  @id @default(cuid())
  name    String
  address String?
  city    String?
  state   String?
  region  String?
  status  String  @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  positions OrgPosition[]

  @@map("org_locations")
}

model OrgChartVersion {
  id          String  @id @default(cuid())
  name        String
  description String?
  versionType String  @default("current") @map("version_type")
  isActive    Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  positions       OrgPosition[]
  positionLayouts OrgPositionLayout[]

  @@map("org_chart_versions")
}

model OrgPosition {
  id                  String    @id @default(cuid())
  orgChartVersionId   String    @map("org_chart_version_id")
  title               String
  departmentId        String?   @map("department_id")
  locationId          String?   @map("location_id")
  reportsToPositionId String?   @map("reports_to_position_id")
  status              String    @default("open")
  targetHireDate      DateTime? @map("target_hire_date")
  notes               String?
  salaryMin           Float?    @map("salary_min")
  salaryMid           Float?    @map("salary_mid")
  salaryMax           Float?    @map("salary_max")
  payFrequency        String    @default("annual") @map("pay_frequency")
  budgetStatus        String    @default("budgeted") @map("budget_status")
  sortOrder           Int?      @map("sort_order")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  version       OrgChartVersion         @relation(fields: [orgChartVersionId], references: [id], onDelete: Cascade)
  department    OrgDepartment?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  location      OrgLocation?            @relation(fields: [locationId], references: [id], onDelete: SetNull)
  reportsTo     OrgPosition?            @relation("OrgReportsTo", fields: [reportsToPositionId], references: [id], onDelete: SetNull)
  directReports OrgPosition[]           @relation("OrgReportsTo")
  assignments       OrgPositionAssignment[]
  certifications    OrgPositionCertification[]
  careerPathsFrom   OrgCareerPath[]              @relation("CareerPathFrom")
  careerPathsTo     OrgCareerPath[]              @relation("CareerPathTo")
  successors        OrgSuccessor[]
  relationshipsFrom OrgPositionRelationship[]    @relation("RelationshipFrom")
  relationshipsTo   OrgPositionRelationship[]    @relation("RelationshipTo")
  layouts           OrgPositionLayout[]

  @@map("org_positions")
}

model OrgPositionAssignment {
  id             String    @id @default(cuid())
  positionId     String    @map("position_id")
  userId         String?   @map("user_id")
  assignmentType String    @default("primary") @map("assignment_type")
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  position OrgPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  // user_id is a plain scalar reference to users.id — no Prisma relation so the User model
  // remains unmodified. User data is fetched via a separate query in queries.ts.

  @@map("org_position_assignments")
}

model OrgCertification {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  issuingBody String?  @map("issuing_body")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  positionCerts OrgPositionCertification[]
  userCerts     OrgUserCertification[]

  @@map("org_certifications")
}

model OrgPositionCertification {
  id               String   @id @default(cuid())
  positionId       String   @map("position_id")
  certificationId  String   @map("certification_id")
  requirementLevel String   @default("required") @map("requirement_level")
  createdAt        DateTime @default(now()) @map("created_at")

  position      OrgPosition      @relation(fields: [positionId],      references: [id], onDelete: Cascade)
  certification OrgCertification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@unique([positionId, certificationId])
  @@map("org_position_certifications")
}

model OrgUserCertification {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  certificationId String    @map("certification_id")
  issuedDate      DateTime? @map("issued_date")
  expiryDate      DateTime? @map("expiry_date")
  credentialId    String?   @map("credential_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  certification OrgCertification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  // user_id is a plain scalar reference to users.id — module isolation pattern

  @@unique([userId, certificationId])
  @@map("org_user_certifications")
}

model OrgCareerPath {
  id                    String   @id @default(cuid())
  fromPositionId        String   @map("from_position_id")
  toPositionId          String   @map("to_position_id")
  typicalTimelineMonths Int?     @map("typical_timeline_months")
  notes                 String?  @db.Text
  createdAt             DateTime @default(now()) @map("created_at")

  fromPosition OrgPosition @relation("CareerPathFrom", fields: [fromPositionId], references: [id], onDelete: Cascade)
  toPosition   OrgPosition @relation("CareerPathTo",   fields: [toPositionId],   references: [id], onDelete: Cascade)

  @@unique([fromPositionId, toPositionId])
  @@map("org_career_paths")
}

model OrgSuccessor {
  id         String   @id @default(cuid())
  positionId String   @map("position_id")
  userId     String   @map("user_id")
  rank       Int      @default(1)
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  position OrgPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  // user_id is a plain scalar reference to users.id — module isolation pattern

  @@unique([positionId, userId])
  @@map("org_successors")
}

model OrgPositionRelationship {
  id               String   @id @default(cuid())
  fromPositionId   String   @map("from_position_id")
  toPositionId     String   @map("to_position_id")
  relationshipType String   @map("relationship_type")
  notes            String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  fromPosition OrgPosition @relation("RelationshipFrom", fields: [fromPositionId], references: [id], onDelete: Cascade)
  toPosition   OrgPosition @relation("RelationshipTo",   fields: [toPositionId],   references: [id], onDelete: Cascade)

  @@unique([fromPositionId, toPositionId, relationshipType])
  @@index([fromPositionId])
  @@index([toPositionId])
  @@map("org_position_relationships")
}

// ─── Admin Audit Log ──────────────────────────────────────────────────────────

model AdminAuditLog {
  id             String   @id @default(cuid())
  adminId        String   @map("admin_id")
  adminName      String   @map("admin_name")
  action         String
  targetUserId   String?  @map("target_user_id")
  targetUserName String?  @map("target_user_name")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([adminId, createdAt(sort: Desc)])
  @@map("admin_audit_logs")
}

// ─── Warehouses ───────────────────────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  address   String   @default("")
  city      String   @default("")
  state     String   @default("")
  zip       String   @default("")
  country   String   @default("US")
  contact   String   @default("")
  phone     String   @default("")
  email     String   @default("")
  notes     String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("warehouses")
}

// ─── Licenses ─────────────────────────────────────────────────────────────────

enum LicenseStatus {
  Active
  Expiring
  Expired
  Suspended
}

model License {
  id                  String        @id @default(cuid())
  state               String        @default("")
  licenseType         String
  licenseNumber       String        @default("")
  holderName          String        @default("")
  renewalDate         DateTime?
  renewalRequirements String        @default("")
  status              LicenseStatus @default(Active)
  notes               String        @default("")
  attachments         Json          @default("[]")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@map("licenses")
}


model OrgPositionLayout {
  id         String   @id @default(cuid())
  positionId String   @map("position_id")
  versionId  String   @map("version_id")
  viewType   String   @default("org_chart") @map("view_type")
  layoutX    Float    @map("layout_x")
  layoutY    Float    @map("layout_y")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  position OrgPosition    @relation(fields: [positionId], references: [id], onDelete: Cascade)
  version  OrgChartVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([positionId, versionId, viewType])
  @@map("org_position_layouts")
}
